NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=
MONGODB_URI=mongodb://localhost:27017/nurseconnect
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=30d
ADMIN_REGISTRATION_SECRET=

# AI provider: gemini, openai, or groq
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional email notifications
GMAIL_USER=
GMAIL_PASS=

# Long-term interview scheduling
LONGTERM_INTERVIEW_DELAY_MINUTES=60

# Upload limits
MAX_REQUEST_FILE_SIZE_BYTES=8388608
MAX_NURSE_DOCUMENT_SIZE_BYTES=8388608
